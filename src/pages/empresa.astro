---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/common/PageHero.astro';
import VisionSection from '@/components/company/VisionSection.astro';
import MissionSection from '@/components/company/MissionSection.astro';
import HistorySection from '@/components/company/HistorySection.astro';
import CorporateStructureSection from '@/components/company/CorporateStructureSection.astro';
import FounderStorySection from '@/components/company/FounderStorySection.astro';
import PhilosophyValuesSection from '@/components/company/PhilosophyValuesSection.astro';
import DocumentsSection from '@/components/company/DocumentsSection.astro';
import AboutUsSection from '@/components/company/AboutUsSection.astro';
import FarmerCommitmentSection from '@/components/company/FarmerCommitmentSection.astro';
import IntroContactCTA from '@/components/home/IntroContactCTA.astro';
import WhatsAppButton from '@/components/common/WhatsAppButton.astro';
---

<BaseLayout
  title="Nuestra Empresa"
  description="Conoce la historia, visión, misión y estructura corporativa de Asoproaruzi. Empresa exportadora ecuatoriana fundada por Andrea Mendoza, con marcas Salomé, ACMA y Agroproa."
>
  <PageHero
    title="Nuestra Empresa"
    subtitle="Desde Ecuador al mundo: una empresa exportadora con historia, valores y vocación de servicio global."
    breadcrumb="Nuestra Empresa"
    bgColor="bg-brand-dark"
  >
    <!-- Quick nav -->
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      {[
        { label: 'Visión', href: '#vision' },
        { label: 'Misión', href: '#mision' },
        { label: 'Historia', href: '#historia' },
        { label: 'Estructura', href: '#estructura-corporativa' },
        { label: 'Fundadora', href: '#fundadora' },
        { label: 'Filosofía', href: '#filosofia' },
        { label: 'Documentos', href: '#documentos' },
        { label: 'Nosotros', href: '#nosotros' },
        { label: 'Compromiso', href: '#compromiso-campesino' },
      ].map(link => (
        <a
          href={link.href}
          class="px-4 py-2 bg-white/10 hover:bg-brand-green/30 text-white/80 hover:text-white text-sm rounded-xl border border-white/20 hover:border-brand-green/40 transition-all"
        >
          {link.label}
        </a>
      ))}
    </div>
  </PageHero>

  <VisionSection />
  <MissionSection />
  <HistorySection />
  <CorporateStructureSection />
  <FounderStorySection />
  <PhilosophyValuesSection />
  <DocumentsSection />
  <AboutUsSection />
  <FarmerCommitmentSection />
  <IntroContactCTA />
  <WhatsAppButton phone="+593XXXXXXXXX" message="Hola, me gustaría conocer más sobre Asoproaruzi." floatingButton={true} />
</BaseLayout>
