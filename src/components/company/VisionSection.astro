---
import { vision } from '@/data/company';
---

<section id="vision" class="py-20 bg-white scroll-mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      
      <!-- Visual -->
      <div class="relative">
        <div class="bg-gradient-to-br from-brand-green to-brand-green-dark rounded-3xl p-10 text-white relative overflow-hidden">
          <div class="absolute top-0 right-0 w-48 h-48 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
          <div class="text-6xl mb-6">🎯</div>
          <blockquote class="font-display italic text-xl text-white/90 leading-relaxed">
            "Posicionarnos como la empresa líder en exportación de frutas tropicales, reconocidos mundialmente por calidad, innovación y sostenibilidad."
          </blockquote>
          <div class="mt-6 pt-6 border-t border-white/20 flex items-center gap-3">
            <div class="w-8 h-px bg-brand-green"></div>
            <span class="text-brand-green font-semibold text-sm uppercase tracking-wider">Visión Empresarial</span>
          </div>
        </div>
        <!-- Bottom floating card -->
        <div class="absolute -bottom-6 -right-6 bg-brand-green rounded-2xl p-5 shadow-xl max-w-xs">
          <div class="font-semibold text-white text-sm">Referente Internacional</div>
          <div class="text-white/70 text-xs mt-1">En exportación de frutas tropicales sudamericanas</div>
        </div>
      </div>

      <!-- Content -->
      <div>
        <div class="flex items-center gap-3 mb-6">
          <div class="h-px w-8 bg-brand-green"></div>
          <span class="text-brand-green font-semibold text-sm uppercase tracking-widest">Visión</span>
        </div>
        <h2 class="font-display font-bold text-4xl text-brand-dark mb-6 leading-tight">
          Líderes Mundiales en Exportación Agrícola
        </h2>
        <p class="text-gray-600 leading-relaxed text-lg mb-8">
          {vision.content}
        </p>
        <div class="grid grid-cols-2 gap-4">
          {['Calidad Internacional', 'Innovación Constante', 'Sostenibilidad', 'Desarrollo Agrícola'].map(v => (
            <div class="flex items-center gap-2">
              <div class="w-5 h-5 bg-brand-green/10 rounded-full flex items-center justify-center flex-shrink-0">
                <svg width="10" height="10" viewBox="0 0 20 20" fill="currentColor" class="text-brand-green">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              </div>
              <span class="text-gray-700 text-sm font-medium">{v}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
