---
import { history } from '@/data/company';
---

<section id="historia" class="py-20 bg-white scroll-mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-14">
      <div class="flex items-center gap-3 justify-center mb-4">
        <div class="h-px w-8 bg-brand-green"></div>
        <div class="h-1.5 w-1.5 rounded-full bg-brand-green"></div>
        <div class="h-px w-8 bg-brand-green"></div>
      </div>
      <h2 class="font-display font-bold text-3xl md:text-4xl text-brand-dark mb-3">
        {history.title}
      </h2>
      <p class="text-brand-green font-semibold">{history.subtitle}</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">
      
      <!-- Main text -->
      <div class="lg:col-span-3">
        <div class="prose prose-lg max-w-none">
          {history.content.split('\n\n').map(para => (
            <p class="text-gray-600 leading-relaxed mb-5">{para}</p>
          ))}
        </div>
      </div>

      <!-- Key facts sidebar -->
      <div class="lg:col-span-2 space-y-4">
        <h3 class="font-display font-bold text-xl text-brand-dark mb-6">Datos Clave</h3>
        
        {[
          { label: 'Fundadora', value: 'Andrea Mendoza', icon: '👩‍💼' },
          { label: 'País de origen', value: 'Ecuador', icon: '🇪🇨' },
          { label: 'Especialidad', value: 'Productos Agrícolas Perecederos y Snacks', icon: '🍌' },
          { label: 'Mercados principales', value: 'EE.UU. y Chile', icon: '🌍' },
          { label: 'Origen de productos', value: 'Ecuador y Perú', icon: '🌿' },
          { label: 'Marcas comerciales', value: 'Salomé, ACMA y Agroproa', icon: '🏷️' },
        ].map(fact => (
          <div class="bg-brand-cream rounded-xl p-5 flex items-start gap-4 border border-gray-100">
            <div class="text-2xl flex-shrink-0">{fact.icon}</div>
            <div>
              <div class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">{fact.label}</div>
              <div class="font-semibold text-brand-dark text-sm">{fact.value}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
