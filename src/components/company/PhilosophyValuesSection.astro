---
import { values } from '@/data/company';
---

<section id="filosofia" class="py-20 bg-brand-cream scroll-mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <div class="text-center mb-14">
      <div class="flex items-center gap-3 justify-center mb-4">
        <div class="h-px w-8 bg-brand-green"></div>
        <div class="h-1.5 w-1.5 rounded-full bg-brand-green"></div>
        <div class="h-px w-8 bg-brand-green"></div>
      </div>
      <h2 class="font-display font-bold text-3xl md:text-4xl text-brand-dark mb-3">
        Filosofía Empresarial y Valores
      </h2>
      <p class="text-gray-500 text-lg max-w-2xl mx-auto">
        Los pilares que guían cada decisión, cada relación y cada exportación que realizamos.
      </p>
    </div>

    <!-- Intro quote -->
    <div class="bg-brand-dark rounded-3xl p-10 text-white text-center mb-12 relative overflow-hidden">
      <div class="absolute inset-0 opacity-10" aria-hidden="true" style="background-image: url('data:image/svg+xml,%3Csvg width=\'60\' height=\'60\' viewBox=\'0 0 60 60\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cg fill=\'none\' fill-rule=\'evenodd\'%3E%3Cg fill=\'%23ffffff\' fill-opacity=\'0.4\'%3E%3Cpath d=\'M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z\'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
      <p class="font-display italic text-2xl text-white/90 max-w-3xl mx-auto leading-relaxed relative">
        "Somos más que una empresa exportadora: somos el aliado estratégico que hace posible el comercio global de calidad, conectando origen y destino con transparencia, eficiencia y valores sólidos."
      </p>
    </div>

    <!-- Values grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {values.map((value, i) => (
        <div class="bg-white rounded-2xl p-7 border border-gray-100 hover:shadow-xl transition-all duration-300 hover:-translate-y-1 group">
          <div class="flex items-start gap-4 mb-4">
            <div class="text-3xl w-12 h-12 bg-brand-green/10 rounded-xl flex items-center justify-center flex-shrink-0">
              {value.icon}
            </div>
            <div>
              <div class="text-xs text-brand-green font-semibold uppercase tracking-widest mb-1">Valor {i + 1}</div>
              <h3 class="font-display font-bold text-lg text-brand-dark group-hover:text-brand-green transition-colors">
                {value.title}
              </h3>
            </div>
          </div>
          <p class="text-gray-500 text-sm leading-relaxed">
            {value.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
