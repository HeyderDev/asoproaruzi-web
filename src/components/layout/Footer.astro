---
import { navLinks } from '@/data/navigation';
import { socialLinks } from '@/data/contact';
---

<footer class="bg-brand-dark text-white">
  <!-- Main footer -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      
      <!-- Columna 1: Logo + Descripción -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 bg-brand-green rounded-lg flex items-center justify-center flex-shrink-0">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
              <path d="M12 2C8 2 4 5 4 10c0 3 1.5 5 3.5 7L12 22l4.5-5C18.5 15 20 13 20 10c0-5-4-8-8-8z" fill="white" opacity="0.9"/>
              <path d="M12 6c-2.5 0-4 2-4 4s1.5 4 4 4 4-2 4-4-1.5-4-4-4z" fill="white"/>
            </svg>
          </div>
          <div>
            <div class="text-brand-green font-display font-bold text-xl tracking-wider">ASOPROARUZI</div>
            <div class="text-white/50 text-xs tracking-widest uppercase">Exportación Agrícola</div>
          </div>
        </a>
        <p class="text-white/60 text-sm leading-relaxed mb-6 max-w-md">
          Empresa exportadora ecuatoriana especializada en la comercialización de productos agrícolas perecederos y snacks de alta calidad. Llevamos los mejores productos de Ecuador y Perú al mundo.
        </p>
        <!-- Marcas -->
        <div class="flex flex-wrap gap-2">
          {['Salomé', 'ACMA LLC', 'Agroproa'].map(brand => (
            <span class="px-3 py-1 bg-white/10 text-white/70 text-xs rounded-full border border-white/20">{brand}</span>
          ))}
        </div>
      </div>

      <!-- Columna 2: Navegación -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-widest mb-5">Navegación</h3>
        <ul class="space-y-3">
          {navLinks.map(link => (
            <li>
              <a href={link.href} class="text-white/60 hover:text-brand-green transition-colors text-sm flex items-center gap-2 group">
                <span class="w-4 h-px bg-brand-green/40 group-hover:w-6 group-hover:bg-brand-green transition-all duration-300"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna 3: Contacto Rápido -->
      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-widest mb-5">Contacto</h3>
        <ul class="space-y-4">
          <li class="flex items-start gap-3">
            <span class="text-brand-green mt-0.5 flex-shrink-0">📍</span>
            <span class="text-white/60 text-sm">Ecuador (Sede principal)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-brand-green mt-0.5 flex-shrink-0">📍</span>
            <span class="text-white/60 text-sm">Perú (Extensión Agroproa)</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-brand-green mt-0.5 flex-shrink-0">✉️</span>
            <a href="mailto:info@asoproaruzi.com" class="text-white/60 hover:text-brand-green transition-colors text-sm">
              info@asoproaruzi.com
            </a>
          </li>
          <li class="mt-2">
            <a
              href="https://wa.me/593XXXXXXXXX?text=Hola%2C%20me%20gustar%C3%ADa%20m%C3%A1s%20informaci%C3%B3n%20sobre%20sus%20productos"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 px-4 py-2 bg-green-600 hover:bg-green-500 text-white text-sm font-medium rounded-lg transition-colors"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893A11.82 11.82 0 0020.885 3.488"/>
              </svg>
              WhatsApp
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-white/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-white/40 text-sm text-center sm:text-left">
        © {new Date().getFullYear()} Asoproaruzi. Todos los derechos reservados.
      </p>
      <p class="text-white/30 text-xs">
        Ecuador 🇪🇨 · Perú 🇵🇪 · EE.UU. 🇺🇸
      </p>
    </div>
  </div>
</footer>
