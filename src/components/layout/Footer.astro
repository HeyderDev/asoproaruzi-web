---
import { navLinks } from '@/data/navigation';
import { socialLinks } from '@/data/contact';
---

<footer class="bg-brand-green-50 text-brand-dark border-t border-brand-green-100 relative">
  <div class="max-w-[1600px] mx-auto flex flex-col lg:flex-row items-center">
    
    <!-- Lado Izquierdo: Contactos (Aprox 35% a 40% width) -->
    <div class="w-full lg:w-[50%] px-6 py-12 md:px-12 flex flex-col justify-center">
      <h2 class="text-4xl md:text-[3.5rem] font-black text-brand-dark uppercase tracking-tighter mb-10 leading-none">
        CONTACTENOS
      </h2>

      <!-- Ecuador Block -->
      <div class="mb-10 text-gray-700">
        <h3 class="text-lg font-semibold text-brand-green-700 mb-4 uppercase tracking-wider">Ecuador</h3>
        <ul class="space-y-3 font-medium">
          <li>Teléfonos: <span class="text-brand-dark">+(593) 098 2937 360</span></li>
          <li>E-mail: <a href="mailto:info@asoproaruzi.com" class="hover:text-brand-green transition-colors underline decoration-brand-green/30 underline-offset-4 font-bold">info@asoproaruzi.com</a></li>
          <li class="leading-relaxed pr-4 text-gray-600">Dirección: Av la Esperanza y 3 de Julio SN. El Carmen. Manabí. Ecuador.</li>
        </ul>
        <a 
          href="https://wa.me/5930982937360" 
          target="_blank" 
          class="mt-6 block w-full bg-brand-green hover:bg-brand-green-light text-white text-center font-bold py-3 px-4 rounded transition-colors uppercase tracking-wider text-sm shadow-lg"
        >
          WhatsApp
        </a>
      </div>

      <!-- Peru Block -->
      <div class="text-gray-700">
        <h3 class="text-lg font-semibold text-brand-green-700 mb-4 uppercase tracking-wider">Peru</h3>
        <ul class="space-y-3 font-medium">
          <li>Teléfonos: <span class="text-brand-dark">+(593) 098 2937 360</span></li>
          <li>E-mail: <a href="mailto:info@asoproaruzi.com" class="hover:text-brand-green transition-colors underline decoration-brand-green/30 underline-offset-4 font-bold">info@asoproaruzi.com</a></li>
          <li class="leading-relaxed pr-4 text-gray-600">Dirección: Av la Esperanza y 3 de Julio SN. El Carmen. Manabí. Ecuador.</li>
        </ul>
        <a 
          href="https://wa.me/5930982937360" 
          target="_blank" 
          class="mt-6 block w-full bg-brand-green hover:bg-brand-green-light text-white text-center font-bold py-3 px-4 rounded transition-colors uppercase tracking-wider text-sm shadow-lg"
        >
          WhatsApp
        </a>
      </div>
    </div>

    <!-- Lado Derecho: Mapa (Aprox 60% a 65% width) -->
    <div class="w-full lg:w-[50%] p-6 lg:p-12 flex justify-center items-center">
      <div class="w-full max-w-[600px] aspect-square lg:aspect-video bg-white rounded-2xl shadow-xl overflow-hidden relative border border-brand-green-100">
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3989.7042817282865!2d-79.46740692419142!3d-0.2709299997233819!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x902b4bbfa35d0f6b%3A0xe549cedee9a5da98!2sEl%20Carmen%2C%20Ecuador!5e0!3m2!1sen!2sus!4v1700685655412!5m2!1sen!2sus" 
          class="w-full h-full border-0 transition-all duration-500" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade">
        </iframe>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="bg-brand-green/10 border-t border-brand-green-100">
    <div class="max-w-[1600px] mx-auto px-6 py-4 flex flex-col md:flex-row items-center justify-between gap-3">
      <p class="text-brand-dark/50 text-sm font-medium">
        © {new Date().getFullYear()} Asoproaruzi. Todos los derechos reservados.
      </p>
    </div>
  </div>
</footer>
