---
import CTAButton from '@/components/common/CTAButton.astro';
import WhatsAppButton from '@/components/common/WhatsAppButton.astro';
---

<section class="py-20 bg-gradient-to-br from-brand-green to-brand-green-dark relative overflow-hidden" aria-label="Contacto CTA">
  <!-- Background decoration -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 left-1/4 w-64 h-64 bg-white/5 rounded-full -translate-y-1/2"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-brand-green/10 rounded-full translate-y-1/2"></div>
  </div>

  <div class="relative max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    
    <div class="flex items-center gap-3 justify-center mb-6">
      <div class="h-px w-8 bg-brand-green"></div>
      <div class="h-1.5 w-1.5 rounded-full bg-brand-green"></div>
      <div class="h-px w-8 bg-brand-green"></div>
    </div>

    <h2 class="font-display font-bold text-4xl md:text-5xl text-white mb-4 leading-tight">
      ¿Listo para Importar Calidad desde Sudamérica?
    </h2>
    <p class="text-white/75 text-lg md:text-xl mb-10 max-w-2xl mx-auto leading-relaxed">
      Contáctenos hoy y descubra cómo Asoproaruzi puede ser su aliado estratégico en la importación de productos agrícolas premium.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <CTAButton href="/contacto" label="Contactar Ahora" variant="gold" size="lg" />
      <WhatsAppButton
        phone="+593XXXXXXXXX"
        message="Hola, estoy interesado en importar productos de Asoproaruzi. ¿Podría enviarme información?"
        label="Escribir por WhatsApp"
      />
    </div>

    <!-- Trust badges -->
    <div class="mt-12 flex flex-wrap items-center justify-center gap-6 text-white/50 text-sm">
      <div class="flex items-center gap-2">
        <span class="text-brand-green">✅</span>
        Empresa Certificada Ecuador
      </div>
      <div class="w-px h-4 bg-white/20 hidden sm:block"></div>
      <div class="flex items-center gap-2">
        <span class="text-brand-green">🇺🇸</span>
        Registro FDA EE.UU.
      </div>
      <div class="w-px h-4 bg-white/20 hidden sm:block"></div>
      <div class="flex items-center gap-2">
        <span class="text-brand-green">🌱</span>
        Exportación Sostenible
      </div>
    </div>
  </div>
</section>
