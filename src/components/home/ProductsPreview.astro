---
import CTAButton from '@/components/common/CTAButton.astro';

const sections = [
  {
    icon: '🏢',
    label: 'Acerca de Nosotros',
    description: 'Conoce la historia, visión, misión y estructura corporativa de Asoproaruzi, conectando Ecuador y Perú con el mundo.',
    items: ['Visión', 'Misión', 'Historia', 'Valores'],
    href: '/empresa',
    color: 'border-brand-green',
    badgeBg: 'bg-brand-green',
    tag: 'Nuestra Empresa',
    cta: 'Conocer más'
  },
  {
    icon: '🍌',
    label: 'Productos',
    description: 'Portafolio completo: productos perecibles frescos, línea selecta de snacks y extensión Origen Perú.',
    items: ['Perecibles', 'Chips & Snacks', 'Origen Perú'],
    href: '/productos',
    color: 'border-brand-green',
    badgeBg: 'bg-brand-green',
    tag: 'Catálogo',
    cta: 'Ver productos'
  },
  {
    icon: '🤝',
    label: 'Compromiso con el Campesino',
    description: 'Trabajamos directamente con los agricultores, garantizando comercio justo, desarrollo sostenible y calidad.',
    items: ['Comercio Justo', 'Sostenibilidad', 'Apoyo Directo'],
    href: '/empresa#compromiso-campesino',
    color: 'border-brand-green',
    badgeBg: 'bg-brand-green',
    tag: 'Responsabilidad',
    cta: 'Leer más'
  },
];
---

<section class="py-20 bg-white" aria-label="Enlaces destacados">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Title -->
    <div class="text-center mb-14">
      <div class="flex items-center gap-3 justify-center mb-4">
        <div class="h-px w-8 bg-brand-green"></div>
        <div class="h-1.5 w-1.5 rounded-full bg-brand-green"></div>
        <div class="h-px w-8 bg-brand-green"></div>
      </div>
      <h2 class="font-display font-bold text-3xl md:text-4xl text-brand-dark mb-3">
        Descubre <span style="color: var(--color-green)">Asoproaruzi</span>
      </h2>
      <p class="text-gray-500 text-lg max-w-2xl mx-auto">
        Conoce más sobre nuestra empresa, explora nuestro catálogo de productos y descubre nuestro compromiso con el desarrollo agrícola.
      </p>
    </div>

    <!-- Section cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      {sections.map(sec => (
        <a
          href={sec.href}
          class:list={[
            'block bg-brand-cream rounded-2xl p-8 border-t-4 hover:shadow-xl transition-all duration-300 hover:-translate-y-2 group',
            sec.color,
          ]}
        >
          <!-- Header -->
          <div class="flex items-start justify-between mb-6">
            <div class="text-4xl">{sec.icon}</div>
            <span class:list={['text-xs font-semibold text-white px-2.5 py-1 rounded-full', sec.badgeBg]}>
              {sec.tag}
            </span>
          </div>

          <!-- Content -->
          <h3 class="font-display font-bold text-xl text-brand-dark mb-3 group-hover:text-brand-green transition-colors">
            {sec.label}
          </h3>
          <p class="text-gray-500 text-sm leading-relaxed mb-5">{sec.description}</p>

          <!-- Sample items -->
          <div class="flex flex-wrap gap-2 mb-6">
            {sec.items.map(item => (
              <span class="px-2.5 py-1 bg-white text-brand-dark text-xs font-medium rounded-lg border border-gray-100">
                {item}
              </span>
            ))}
          </div>

          <!-- Link -->
          <div class="flex items-center gap-2 text-brand-green font-semibold text-sm group-hover:gap-3 transition-all">
            {sec.cta}
            <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
            </svg>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
