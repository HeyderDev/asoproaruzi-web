---
const sections = [
  {
    label: 'Acerca de Nosotros',
    description: 'Conoce la historia, visión, misión y estructura corporativa de Asoproaruzi, conectando Ecuador y Perú con el mundo.',
    href: '/empresa',
    bgImage: '/home/NUESTRA EMPRESA.jpeg'
  },
  {
    label: 'Productos',
    description: 'Portafolio completo: productos perecibles frescos, línea selecta de snacks y extensión Origen Perú.',
    href: '/productos',
    bgImage: '/home/PRODUCTOS.jpeg'
  },
  {
    label: 'Compromiso con el Campesino',
    description: 'Trabajamos directamente con los agricultores, garantizando comercio justo, desarrollo sostenible y calidad.',
    href: '/empresa#compromiso-campesino',
    bgImage: '/home/COMPROMISO CON EL CAMPESINO.jpeg'
  },
];
---

<section class="py-20 bg-white" aria-label="Enlaces destacados">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Title -->
    <div class="text-center mb-14">
      <div class="flex items-center gap-3 justify-center mb-4">
        <div class="h-px w-8 bg-brand-green"></div>
        <div class="h-1.5 w-1.5 rounded-full bg-brand-green"></div>
        <div class="h-px w-8 bg-brand-green"></div>
      </div>
      <h2 class="font-display font-bold text-3xl md:text-4xl text-brand-dark mb-3">
        Descubre <span style="color: var(--color-green)">Asoproaruzi</span>
      </h2>
      <p class="text-gray-500 text-lg max-w-2xl mx-auto">
        Conoce más sobre nuestra empresa, explora nuestro catálogo de productos y descubre nuestro compromiso con el desarrollo agrícola.
      </p>
    </div>

    <!-- Section cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
      {sections.map(sec => (
        <a
          href={sec.href}
          class="relative block rounded-2xl overflow-hidden shadow-lg hover:shadow-2xl transition-all duration-300 hover:-translate-y-2 group h-80 sm:h-96"
        >
          <!-- Background Image with Overlay -->
          <div 
            class="absolute inset-0 bg-cover bg-center transition-transform duration-700 group-hover:scale-110"
            style={`background-image: url('${sec.bgImage}');`}
          ></div>
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/20 group-hover:from-black/90 group-hover:via-black/50 transition-colors duration-300"></div>

          <!-- Content -->
          <div class="relative h-full flex flex-col justify-end p-8">
            <h3 class="font-display font-bold text-2xl text-white mb-3 group-hover:text-brand-green transition-colors">
              {sec.label}
            </h3>
            <p class="text-white/90 text-sm leading-relaxed">
              {sec.description}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
