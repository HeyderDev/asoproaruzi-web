---
import { chipSkus, chipSizes } from '@/data/products';

// Group by size
const getBySizeAndBase = (size: number) => {
  const items = chipSkus.filter(s => s.sizeG === size);
  const bases = [...new Set(items.map(i => i.base))];
  return bases.map(base => ({
    base,
    emoji: items.find(i => i.base === base)?.emoji ?? '🍌',
    flavors: items.filter(i => i.base === base).map(i => i.flavor).filter(Boolean) as string[],
  }));
};
---

<section id="chips" class="py-20 bg-brand-cream scroll-mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Header -->
    <div class="text-center mb-14">
      <div class="flex items-center gap-3 justify-center mb-4">
        <div class="h-px w-8 bg-brand-green"></div>
        <div class="h-1.5 w-1.5 rounded-full bg-brand-green"></div>
        <div class="h-px w-8 bg-brand-green"></div>
      </div>
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-brand-green/10 text-brand-green rounded-full text-sm font-semibold mb-4">
        <span>🍿</span> Línea Chips & Snacks
      </div>
      <h2 class="font-display font-bold text-3xl md:text-4xl text-brand-dark mb-3">
        Chips y Snacks de Alta Calidad
      </h2>
      <p class="text-gray-500 text-lg max-w-2xl mx-auto">
        Plátano, yuca, malanga y camote procesados en múltiples sabores y presentaciones. Perfectos para distribución retail e importación.
      </p>
    </div>

    <!-- Sizes sections -->
    <div class="space-y-8">
      {chipSizes.map(size => {
        const items = getBySizeAndBase(size);
        return items.length > 0 ? (
          <div class="bg-white rounded-2xl overflow-hidden border border-gray-100 hover:shadow-lg transition-shadow">
            <!-- Size header -->
            <div class="bg-brand-dark px-7 py-4 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-brand-green rounded-xl flex items-center justify-center font-bold text-white text-sm">{size}g</div>
                <div>
                  <div class="font-semibold text-white text-sm">Envase {size}g</div>
                  <div class="text-white/50 text-xs">{items.length} {items.length === 1 ? 'producto' : 'productos'} en esta presentación</div>
                </div>
              </div>
              <div class="text-brand-green/60 text-xs font-mono">{items.reduce((acc, i) => acc + Math.max(i.flavors.length, 1), 0)} SKUs</div>
            </div>

            <!-- Products in this size -->
            <div class="p-7">
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
                {items.map(item => (
                  <div class="bg-brand-cream rounded-xl p-5 border border-gray-100">
                    <div class="flex items-center gap-3 mb-3">
                      <span class="text-2xl">{item.emoji}</span>
                      <div class="font-semibold text-brand-dark text-sm">{item.base}</div>
                    </div>
                    {item.flavors.length > 0 ? (
                      <div>
                        <p class="text-xs text-gray-400 uppercase tracking-wider mb-2">Sabores disponibles</p>
                        <div class="flex flex-wrap gap-1.5">
                          {item.flavors.map(f => (
                            <span class="px-2.5 py-1 bg-white rounded-lg text-xs font-medium text-brand-dark border border-gray-200">
                              {f}
                            </span>
                          ))}
                        </div>
                      </div>
                    ) : (
                      <span class="text-xs text-gray-400 italic">Presentación estándar</span>
                    )}
                  </div>
                ))}
              </div>
            </div>
          </div>
        ) : null;
      })}
    </div>

    <!-- Contact for wholesale -->
    <div class="mt-10 bg-brand-green rounded-2xl p-7 text-white text-center">
      <div class="text-2xl mb-2">📦</div>
      <div class="font-display font-bold text-xl mb-2">¿Importación al por Mayor?</div>
      <p class="text-white/80 text-sm mb-5">Contáctenos para obtener precios, disponibilidad y condiciones de exportación del portafolio completo de chips.</p>
      <a href="/contacto" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-brand-green font-semibold rounded-xl hover:bg-white/90 transition-colors">
        Solicitar Información
        <svg class="w-4 h-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
        </svg>
      </a>
    </div>
  </div>
</section>
