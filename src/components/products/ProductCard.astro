---
import { perishables } from '@/data/products';

interface Props {
  product: typeof perishables[0];
}
const { product } = Astro.props;
---

<article class="bg-white rounded-2xl border border-gray-100 overflow-hidden hover:shadow-xl transition-all duration-300 hover:-translate-y-1 group">
  <!-- Header with emoji / image -->
  <div class="bg-gradient-to-br from-brand-green/10 to-brand-green/5 p-8 flex flex-col items-center text-center border-b border-gray-100 group-hover:from-brand-green/20 transition-colors">
    <div class="text-6xl mb-3">{product.emoji}</div>
    <h3 class="font-display font-bold text-xl text-brand-dark group-hover:text-brand-green transition-colors">{product.name}</h3>
    {product.varieties && (
      <div class="flex flex-wrap gap-1 justify-center mt-2">
        {product.varieties.map(v => (
          <span class="text-xs px-2 py-0.5 bg-brand-green/10 text-brand-green rounded-full">{v}</span>
        ))}
      </div>
    )}
  </div>

  <!-- Details -->
  <div class="p-6">
    {product.description && (
      <p class="text-gray-500 text-sm leading-relaxed mb-5">{product.description}</p>
    )}

    <!-- Packaging info -->
    <div class="space-y-2 mb-4">
      <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-2">Empaque y Logística</p>
      {product.packaging.map(pkg => (
        <div class="flex flex-wrap gap-2 text-xs">
          {pkg.weightKg && (
            <span class="px-2 py-1 bg-brand-cream rounded-lg font-medium text-brand-dark">📦 {pkg.weightKg}kg/caja</span>
          )}
          {pkg.boxesPerPallet && (
            <span class="px-2 py-1 bg-brand-cream rounded-lg text-gray-500">{pkg.boxesPerPallet} cajas/pallet</span>
          )}
          {pkg.boxesPerContainer && (
            <span class="px-2 py-1 bg-brand-cream rounded-lg text-gray-500">{pkg.boxesPerContainer} cajas/cont.</span>
          )}
          {pkg.palletsPerContainer && (
            <span class="px-2 py-1 bg-brand-cream rounded-lg text-gray-500">{pkg.palletsPerContainer} pallets</span>
          )}
          {pkg.notes && (
            <span class="px-2 py-1 bg-brand-cream rounded-lg text-gray-400 italic">{pkg.notes}</span>
          )}
        </div>
      ))}
    </div>

    <!-- Season & origin -->
    <div class="flex items-center justify-between pt-4 border-t border-gray-100">
      <div class="flex items-center gap-1.5 text-xs text-gray-400">
        <span>📅</span>
        <span>{product.season}</span>
      </div>
      <div class="flex items-center gap-1 text-xs text-gray-400">
        {product.origin.map(o => <span>🌿 {o}</span>)}
      </div>
    </div>
  </div>
</article>
