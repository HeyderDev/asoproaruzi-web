---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center' | 'right';
  light?: boolean;
  class?: string;
  tag?: 'h1' | 'h2' | 'h3';
  accentWord?: string;
}

const {
  title,
  subtitle,
  align = 'center',
  light = false,
  class: extraClass = '',
  tag: Tag = 'h2',
  accentWord,
} = Astro.props;

const alignClass = {
  left: 'text-left items-start',
  center: 'text-center items-center',
  right: 'text-right items-end',
};
---

<div class:list={['flex flex-col gap-3 mb-10', alignClass[align], extraClass]}>
  <!-- Decorative line -->
  <div class="flex items-center gap-3" class:list={[align === 'center' ? 'justify-center' : '']}>
    <div class="h-px w-8 bg-brand-green"></div>
    <div class="h-1.5 w-1.5 rounded-full bg-brand-green"></div>
    <div class="h-px w-8 bg-brand-green"></div>
  </div>

  <Tag class:list={[
    'font-display font-bold',
    light ? 'text-white' : 'text-brand-dark',
    Tag === 'h1' ? 'text-4xl md:text-5xl lg:text-6xl' : 'text-3xl md:text-4xl',
  ]}>
    {accentWord
      ? <Fragment set:html={title.replace(accentWord, `<span style="color: var(--color-gold)">${accentWord}</span>`)} />
      : title
    }
  </Tag>

  {subtitle && (
    <p class:list={[
      'text-base md:text-lg leading-relaxed max-w-2xl',
      light ? 'text-white/70' : 'text-gray-600',
    ]}>
      {subtitle}
    </p>
  )}
</div>
